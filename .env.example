# LLM provider options: ollama for local development, groq for Streamlit Cloud,
# or template for deterministic no-key fallback.
LLM_PROVIDER=ollama

# Optional local LLM. Defaults to Qwen through Ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Optional online LLM for deployment.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional embedding model. If unavailable, retrieval falls back to TF-IDF.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
USE_CHROMA=1

# Optional deployment artifact. In production mode, missing processed data/indexes
# fail fast unless DATA_ARTIFACT_URL can bootstrap them.
DATA_ARTIFACT_URL=
PRODUCTION_MODE=0

# Frontend origins allowed by the FastAPI CORS layer.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional explicit raw dataset paths. Otherwise scripts/ingest.py will auto-discover data/raw.
PRODUCTS_PATH=
PRICING_PATH=
FEATURES_PATH=
REVIEWS_PATH=
